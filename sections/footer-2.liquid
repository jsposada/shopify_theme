{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{% liquid
  assign gst = settings
  assign container = gst.footer_container
  assign img_logo = gst.logo
  if gst.footer_logo != blank
    assign img_logo = gst.footer_logo
  endif
  assign bdTop = gst.border_top
  assign bdBottom = gst.border_bottom
%}

{%- capture style -%}
  --section-padding-top: {{ gst.padding_top }}px; 
  --section-padding-bottom: {{ gst.padding_bottom }}px; 
{%- endcapture -%}

<footer class="footer footer-2 color-{{ gst.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="{{ container }}">
    <div class="footer__top {% if bdTop %}bdt-1{% endif %} {% if bdBottom %}bdb-1{% endif %} section-py" style="{{ style | strip | strip_newlines }}">
      {% for block in section.blocks %}
        {% assign bst = block.settings %}
        {% if block.type == 'newsletter' %}
          <div class="footer__newsletter flex justify-between items-center">
            <div class="footer__newsletter-top flex items-center gap-30 flex-1">
              <div class="newsletter-heading">
                {%- if block.settings.heading != blank -%}
                  <h4 class="footer__heading mb-10">
                    {{- block.settings.heading -}}
                  </h4>
                {%- endif -%}
                {% if bst.description != blank %}
                  <div class="newsletter__desc rsmb-p">{{ bst.description }}</div>
                {% endif %}
              </div>
              {% render 'form-newsletter' %}
            </div>
            {%- if gst.show_social_media_icons -%}
              {%- render 'social-icons' -%}
            {%- endif -%}
          </div>
        {% endif %}
      {% endfor %}
      {%- if section.blocks.size > 0 -%}
        <div class="footer__top-inner flex -mx-15">
          {%- for block in section.blocks -%}
            {% liquid
              assign bst = block.settings
              if block.type == 'link_list'
                assign classBlockItem = 'footer--menu'
              endif
            %}
            {% unless block.type == 'newsletter' %}
              <div class="footer__top-item px-15 {{ classBlockItem }}" style="--container-width: {{ bst.item_width }}%; --container-width-tablet: {{ bst.item_width_tablets }}%;">
                {% if gst.show_logo and block.type == 'about_us' %}
                  <div class="mb-10 footer__heading  {% unless forloop.first %}flex items-center justify-between{% endunless %}">
                    {%- render 'logo'
                      , img_logo: img_logo
                      , check_index: false -%}
                    {% unless forloop.first %}
                    {% endunless %}
                  </div>
                {% endif %}
                {%- if block.settings.heading != blank -%}
                  <h4 class="footer__heading mb-16 flex items-center justify-between">
                    {{- block.settings.heading -}}
                    {% unless forloop.first %}
                      {% if block.type == 'link_list' or block.type == 'about_us' or block.type == 'payment' %}
                        <span class="icon-toggle relative"></span>
                      {% endif %}
                    {% endunless %}
                  </h4>
                {%- endif -%}

                {%- case block.type -%}
                  {%- when 'link_list' -%}
                    <ul class="footer__menu list-none">
                      {%- for link in block.settings.menu.links -%}
                        <li class="footer__menu-item {% if forloop.last %}mb-0{% else %}mb-20{% endif %}">
                          <a href="{{ link.url }}">
                            {{ link.title }}
                          </a>
                        </li>
                      {% else %}
                        {%- for i in (1..5) -%}
                          <li class="footer__menu-item {% if forloop.last %}mb-0{% else %}mb-20{% endif %}">
                            <a href="#">
                              {{ 'onboarding.menu_title' | t }}
                            </a>
                          </li>
                        {%- endfor -%}
                      {%- endfor -%}
                    </ul>
                  {%- when 'about_us' -%}
                    {%- if block.settings.description != blank -%}
                      <div class="mb-12 rsmb-p">{{ block.settings.description }}</div>
                    {%- endif -%}
                    <div class="">
                      {%- if settings.open_time and block.settings.show_open_time -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          <p class="mb-0">
                            {{ 'sections.footer.open_time' | t }}: {{ settings.open_time }}
                          </p>
                        </div>
                      {%- endif -%}
                      {%- if settings.store_address and block.settings.show_address -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          <p class="mb-0">
                            {{ 'sections.footer.address' | t }}: {{ settings.store_address }}</p>
                        </div>

                      {%- endif -%}
                      {%- if settings.store_phone and block.settings.show_phone -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          <p class="mb-0">
                            <a href="tel:{{ settings.store_phone }}" class="">
                              {{ 'sections.footer.phone' | t }}:
                              <strong>{{ settings.store_phone }}</strong>
                            </a>
                          </p>
                        </div>
                        {%- comment -%} Segundo teléfono añadido {%- endcomment -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          <p class="mb-0">
                            <a href="tel:+56957709915" class="">
                              {{ 'sections.footer.phone' | t }} 2:
                              <strong>+56 9 7767 0252</strong>
                            </a>
                          </p>
                        </div>
                      {%- endif -%}
                      {%- if settings.store_email and block.settings.show_email -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          <p class="mb-0">
                            <a href="mailto:{{ settings.store_email }}" class="">
                              {{ 'sections.footer.email' | t }}:
                              <strong>{{ settings.store_email }}</strong>
                            </a>
                          </p>
                        </div>
                      {%- endif -%}
                      {%- if bst.show_social -%}
                        <div class="flex gap-5 mb-16 items-baseline">
                          {%- render 'social-icons' -%}
                        </div>
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              </div>
            {% endunless %}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
  {% if gst.copyright != blank or gst.payment_enable or gst.show_social_media_icons %}
    <div class="footer__bottom  color-{{ gst.color_scheme_ftb }} gradient">
      <div class="footer__bottom-wrapper py-30 {{ container }} flex items-center {% if gst.show_social_media_icons %} justify-between{% else %}justify-center{% endif %}">
        {%- if gst.payment_enable -%}
          <div class="footer__bottom-payment footer__menu">
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        {% if gst.copyright != blank %}
          <div class="footer__bottom-copyright">
            <div class="rsmb-p">{{ gst.copyright }}</div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}
</footer>


{% schema %}
  {
    "name": "t:sections.footer.name",
    "blocks": [
      {
        "type": "newsletter",
        "name": "Newsletter",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Sign Up to Newsletter"
          }, {
            "type": "richtext",
            "id": "description",
            "label": "Description",
            "default": "<p>Enter your email address to get $10 off your first order and free shipping. Updates information on Sales and Offers.</p>"
          }, {
            "type": "range",
            "id": "item_width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item desktop",
            "default": 25
          }, {
            "type": "range",
            "id": "item_width_tablets",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item tablets",
            "default": 25
          }
        ]
      }, {
        "type": "about_us",
        "name": "About",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "richtext",
            "id": "description",
            "label": "Description"
          },
          {
            "type": "header",
            "content": "Contact information",
            "info": "Go to \"Theme settings > \" to update these information."
          },
          {
            "type": "checkbox",
            "id": "show_address",
            "label": "Show address",
            "default": false
          }, {
            "type": "checkbox",
            "id": "show_phone",
            "label": "Show phone number",
            "default": false
          }, {
            "type": "checkbox",
            "id": "show_email",
            "label": "Show email",
            "default": false
          }, {
            "type": "checkbox",
            "id": "show_open_time",
            "label": "Show open time",
            "default": false
          }, {
            "type": "range",
            "id": "item_width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item desktop",
            "default": 25
          }, {
            "type": "range",
            "id": "item_width_tablets",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item tablets",
            "default": 25
          }
        ]
      }, {
        "type": "link_list",
        "name": "t:sections.footer.blocks.link_list.name",
        "settings": [
          {
            "type": "inline_richtext",
            "id": "heading",
            "default": "Quick links",
            "label": "t:sections.footer.blocks.link_list.settings.heading.label"
          }, {
            "type": "link_list",
            "id": "menu",
            "default": "footer",
            "label": "t:sections.footer.blocks.link_list.settings.menu.label",
            "info": "t:sections.footer.blocks.link_list.settings.menu.info"
          }, {
            "type": "range",
            "id": "item_width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item desktop",
            "default": 25
          }, {
            "type": "range",
            "id": "item_width_tablets",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "label": "Width item tablets",
            "default": 25
          }
        ]
      }
    ],
    "settings": []
  }
{% endschema %}