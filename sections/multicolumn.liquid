              },
              {
                "value": "lg:w-1/3",
                "label": "33%"
              },
              {
                "value": "lg:w-1/2",
                "label": "50%"
              }, {
                "value": "lg:w-4/6",
                "label": "66%"
              }, {
                "value": "w-3/4",
                "label": "75%"
              }, {
                "value": "lg:w-full",
                "label": "100%"
              }
            ]
          },
          {
            "type": "select",
            "id": "col_width_tablets",
            "label": "Banner width tablets",
            "default": "md:w-1/3",
            "options": [
              {
                "value": "md:w-1/5",
                "label": "20%"
              },
              {
                "value": "md:w-1/4",
                "label": "25%"
              },
              {
                "value": "md:w-1/3",
                "label": "33%"
              },
              {
                "value": "md:w-1/2",
                "label": "50%"
              }, {
                "value": "md:w-4/6",
                "label": "66%"
              }, {
                "value": "md:w-3/4",
                "label": "75%"
              }, {
                "value": "md:w-full",
                "label": "100%"
              }
            ]
          },
          {
            "type": "select",
            "id": "col_width_mobile",
            "label": "Banner width mobile",
            "default": "w-1/3",
            "options": [
              {
                "value": "w-1/5",
                "label": "20%"
              },
              {
                "value": "w-1/4",
                "label": "25%"
              },
              {
                "value": "w-1/3",
                "label": "33%"
              },
              {
                "value": "w-1/2",
                "label": "50%"
              }, {
                "value": "w-4/6",
                "label": "66%"
              }, {
                "value": "w-3/4",
                "label": "75%"
              }, {
                "value": "w-full",
                "label": "100%"
              }
            ]
          },
          {
            "type": "number",
            "id": "width_custom",
            "label": "Max width content"
          }, {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.multicolumn.blocks.column.settings.image.label"
          }, {
            "type": "checkbox",
            "id": "show_image",
            "label": "Show image",
            "default": false
          }, {
            "type": "inline_richtext",
            "id": "title",
            "default": "Column",
            "label": "t:sections.multicolumn.blocks.column.settings.title.label"
          }, {
            "type": "richtext",
            "id": "description",
            "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
            "label": "t:sections.multicolumn.blocks.column.settings.text.label"
          }, {
            "type": "text",
            "id": "btn_content",
