              }, {
                "value": "_blank",
                "label": "New tab"
              }
            ],
            "label": "Button open link in",
            "default": "_blank"
          }, {
            "type": "url",
            "id": "link",
            "label": "t:sections.multicolumn.blocks.column.settings.link.label"
          }, {
            "type": "select",
            "id": "type_button",
            "label": "Type button",
            "default": "primary",
            "options": [
