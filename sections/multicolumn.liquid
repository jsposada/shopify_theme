{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sst = section.settings
  assign container = sst.container
  assign column_align = sst.column_alignment
  assign bg_img = sst.background_section
  assign hvr_effect = ''
  if sst.hover_effect == 'hvr_zoom'
    assign hvr_effect = 'hvr__zoom'
  elsif sst.hover_effect == 'translate_to_top'
    assign hvr_effect = 'hvr__translate-top'
  elsif sst.hover_effect == 'overlay_bg'
    assign hvr_effect = 'hvr__overlay-bg'
  endif
-%}
{%- capture style -%}
  --section-padding-top: {{ sst.padding_top }}px; 
  --section-padding-bottom: {{ sst.padding_bottom }}px;
  {% if sst.height_mobile == 'custom_height' %}
    --height-img-desktop: {{ sst.height_image_desktop }}px;
    --height-img-tablet: {{ sst.height_image_tablet }}px;
    --height-img: {{ sst.height_img_mobile }}px;
    {% assign classImgCustom = 'h-full custom-height-img' %}
  {% endif %} 
{%- endcapture -%}
<div class="tp-multicolumn color-{{ sst.color_scheme }} gradient section-py {% if sst.reset_spacing == false %}section-mb{% endif %}" style="
    {{ style | strip | strip_newlines }};
    {% if bg_img != blank %}
      background: url({{ bg_img | image_url: width: bg_img.width, height: bg_img.height }});
      background-size: cover;
      background-repeat: no-repeat!important;
      background-position: center center!important;
    {% endif %}
  ">
  <div class="{{ container }} section-full">
    {% render 'section-header'
      , sst: sst %}
    {% if section.blocks.size > 0 %}
      <div class="{%- if sst.button_label != blank -%} mb-40{% endif %} tp-multicolumn__content">
        <div class="tp-multicolumn__inner flex flex-wrap tp-grid {% if sst.nowrap_item %}tp-grid-nowrap{% endif %}">
          {%- for block in section.blocks -%}
            {% liquid
              assign bst = block.settings
              assign col_width_desktop = bst.col_width_desktop
              assign col_width_tablets = bst.col_width_tablets
              assign col_width_mobile = bst.col_width_mobile
            %}
            <div class="tp-multicolumn__item relative {{ hvr_effect }} overflow-hidden {{ col_width_mobile }} {{ col_width_tablets }} {{ col_width_desktop }} {{ column_align }} {% if sst.show_border_separate %}border-separate{% endif %}{% if bst.custom_width == 'custom' %}custom-width{% endif %}" style="--width-custom: {{ bst.width_custom }}px">
              {%- if bst.show_image -%}
                <div class="tp-multicolumn__item-img bd-radius relative {% if bst.image == blank %}no-image{% endif %}">
                  {% if bst.link != blank %}
                    <a
                      {% if bst.link == blank %}
                      role="link"
                      aria-disabled="true"
                      {% else %}
                      href="{{ bst.link }}"
                      {% endif %}
                      {%- if bst.open_link == '_blank' -%}
                      target="_blank"
                      {%- else -%}
                      target="_self"
                      {%- endif -%}
                      class="link-absolute absolute top-0 right-0 left-0 bottom-0 z-20 cursor-pointer"></a>
                  {% endif %}
                  {% render 'responsive-image'
                    , image: bst.image
                    , aspect_ratio: sst.image_ratio
                    , custom_ratio: sst.custom_ratio
                    , class: classImgCustom
                    , w_default: 280
                    , h_default: 495
                  %}
                </div>
              {%- endif -%}
              {%- if bst.title != blank or bst.description != blank or bst.btn_content != blank -%}
                <div class="tp-multicolumn__item-info {% if bst.width_custom != blank %} custom-width{% endif %} {% if sst.design_banner == 'text-overlay-image' %} absolute left-30 top-1/2 -translate-y-1/2{% else %}{% if bst.show_image %}mt-24{% endif %}{% endif %}">
                  {%- if bst.title != blank -%}
                    <h3 class="mb-12">{{ bst.title }}</h3>
                  {%- endif -%}
                  {%- if bst.description != blank -%}
                    <div class="mb-15 rsmb-p">{{ bst.description }}</div>
                  {%- endif -%}
                  {%- if bst.btn_content != blank -%}
                    <div>
                      <a
                        {% if bst.link == blank %}
                        role="link"
                        aria-disabled="true"
                        {% else %}
                        href="{{ bst.link }}"
                        {% endif %}
                        {%- if bst.open_link == '_blank' -%}
                        target="_blank"
                        {%- else -%}
                        target="_self"
                        {%- endif -%}
                        class="tp-btn tp-btn__{{ bst.type_button }} n-hvr">
                        {{ bst.btn_content | escape }}
                      </a>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {% endif %}
    {%- if sst.button_label != blank -%}
      <div class="text-center">
        <a
          class="tp-btn {{ sst.button_type }} n-hvr"
          {% if sst.button_link == blank %}
          role="link"
          aria-disabled="true"
          {% else %}
          href="{{ sst.button_link }}"
          {% endif %}>
          {{ sst.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
  {
    "name": "t:sections.multicolumn.name",
    "tag": "section",
    "settings": [
      {
        "type": "header",
        "content": "Section header"
      },
      {
        "type": "checkbox",
        "id": "show_heading_header",
        "label": "Show \"Section header\"",
        "default": false
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Title"
      },
      {
        "type": "richtext",
        "id": "description",
        "label": "Description",
        "default": "<p></p>"
      }, {
        "type": "select",
        "id": "text_alignment",
        "label": "Text alignment",
        "default": "text-center",
        "options": [
          {
            "value": "text-left",
            "label": "Left"
          }, {
            "value": "text-center",
            "label": "Center"
          }, {
            "value": "text-right",
            "label": "Right"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "show_button",
        "label": "Show button",
        "default": true
      }, {
        "type": "text",
        "id": "text_btn",
        "label": "Text button",
        "default": "See more"
      }, {
        "type": "paragraph",
        "content": "----------------------------------------"
      }, {
        "type": "header",
        "content": "General"
      }, {
        "type": "select",
        "id": "container",
        "label": "Layout",
        "default": "container",
        "options": [
          {
            "value": "container",
            "label": "Default"
          }, {
            "value": "container-fluid",
            "label": "Fluid container"
          }, {
            "value": "full-width",
            "label": "Full width"
          }
        ]
      }, {
        "type": "select",
        "id": "hover_effect",
        "label": "Hover effect",
        "options": [
          {
            "value": "hvr_none",
            "label": "None"
          }, {
            "value": "hvr_zoom",
            "label": "Zoom"
          }, {
            "value": "translate_to_top",
            "label": "Translate to top"
          }, {
            "value": "overlay_bg",
            "label": "Overlay background"
          }
        ],
        "default": "hvr_zoom"
      }, {
        "type": "image_picker",
        "id": "background_section",
        "label": "Background section"
      }, {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.label",
        "default": "background-1"
      }, {
        "type": "select",
        "id": "image_ratio",
        "default": "original",
        "label": "Image ratio",
        "options": [
          {
            "value": "original",
            "label": "Original aspect ratio"
          },
          {
            "value": "1/1",
            "label": "1:1"
          },
          {
            "value": "3/4",
            "label": "3:4"
          },
          {
            "value": "4/3",
            "label": "4:3"
          }, {
            "value": "16/9",
            "label": "16:9"
          }, {
            "value": "custom",
            "label": "Custom ratio"
          }
        ]
      }, {
        "type": "text",
        "id": "custom_ratio",
        "label": "Custom ratio",
        "default": "21:9"
      }, {
        "type": "select",
        "id": "height_mobile",
        "label": "Height",
        "options": [
          {
            "value": "default",
            "label": "Default"
          }, {
            "value": "custom_height",
            "label": "Custom height"
          }
        ],
        "default": "default"
      }, {
        "type": "text",
        "id": "height_image_desktop",
        "label": "Height image desktop",
        "default": "500"
      }, {
        "type": "text",
        "id": "height_image_tablet",
        "label": "Height image tablet",
        "default": "500"
      }, {
        "type": "text",
        "id": "height_img_mobile",
        "label": "Height image mobile",
        "default": "350"
      }, {
        "type": "select",
        "id": "column_alignment",
        "options": [
          {
            "value": "text-left",
            "label": "t:sections.multicolumn.settings.column_alignment.options__1.label"
          }, {
            "value": "text-center",
            "label": "t:sections.multicolumn.settings.column_alignment.options__2.label"
          }, {
            "value": "text-right",
            "label": "Right"
          }
        ],
        "default": "text-left",
        "label": "Column alignment"
      }, {
        "type": "select",
        "id": "design_banner",
        "label": "Design",
        "options": [
          {
            "value": "text-overlay-image",
            "label": "Text overlay image"
          }, {
            "value": "text-below-image",
            "label": "Text below image"
          }
        ]
      }, {
        "type": "checkbox",
        "id": "show_border_separate",
        "label": "Show border separate",
        "default": false
      }, {
        "type": "text",
        "id": "button_label",
        "default": "Button label",
        "label": "t:sections.multicolumn.settings.button_label.label"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "t:sections.multicolumn.settings.button_link.label"
      }, {
        "type": "select",
        "id": "button_type",
        "options": [
          {
            "value": "tp-btn__primary",
            "label": "Button primary"
          }, {
            "value": "tp-btn__secondary",
            "label": "Button secondary"
          }, {
            "value": "tp-btn__underline",
            "label": "Button underline"
          }
        ],
        "label": "Button type",
        "default": "tp-btn__primary"
      }, {
        "type": "header",
        "content": "t:sections.multicolumn.settings.header_mobile.content"
      }, {
        "type": "checkbox",
        "id": "nowrap_item",
        "label": "Nowrap item",
        "default": false
      }, {
        "type": "checkbox",
        "id": "reset_spacing",
        "label": "Remove default space between sections",
        "default": false
      }, {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "blocks": [
      {
        "type": "column",
        "name": "t:sections.multicolumn.blocks.column.name",
        "settings": [
          {
            "type": "select",
