{{ 'top-bar.css' | asset_url | stylesheet_tag }}
{% liquid
  assign gst = settings
  assign st = section.settings
  assign container = st.container
  assign grid_background = st.show_background_grid
  assign text_message = st.message
  assign show_language = st.show_language
  assign show_currency = st.show_currency
  assign hideTabletMobile = false


  if st.hidden_menu_tablet_mobile and st.hidden_social_tablet_mobile and st.hidden_message_tablet_mobile and st.hidden_language_tablet_mobile and st.hidden_currency_tablet_mobile and st.hidden_account_tablet_mobile
    assign hideTabletMobile = true
  endif
%}

<div class="tp__top-bar {% if hideTabletMobile %} hidden lg:block{% endif %} {% if st.hidden_top_bar_tablet_mobile %} hidden lg:block {% endif %}{% if grid_background %}background-grid{% endif %} color-{{ section.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
  <div class="{{ container }}">
    <div class="tp__top-bar-inner flex flex-col min-[992px]:flex-row items-center justify-between gap-0 min-[992px]:gap-30 py-10 {% if st.border_bottom %}bdb-1{% endif %}">
      <div class="col-left flex-wrap min-[992px]:w-1/3 {% if st.hidden_menu_tablet_mobile and  st.hidden_social_tablet_mobile %} hidden lg:block {% endif %}">
        <div class=" flex items-center justify-center min-[992px]:justify-start py-10 min-[992px]:py-0 gap-24">
          {% if st.menu_top_bar != blank %}
            <ul class="list-none color-heading flex items-center gap-30 {% if st.hidden_menu_tablet_mobile %} hidden lg:block {% endif %}">
              {%- for link in st.menu_top_bar.links limit: 3 -%}
                <li class="menu-item">
                  <a href="{{ link.url }}">
                    {{ link.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {% endif %}
          {% if st.show_social %}
            <div class="{% if st.hidden_social_tablet_mobile %} hidden lg:block {% endif %}">
              {%- render 'social-icons'
                , flow: 'down' -%}
            </div>
          {% endif %}
        </div>
      </div>
      {% if text_message != blank %}
        <div class="col-center flex items-center justify-center min-[992px]:w-1/3 {% if st.hidden_message_tablet_mobile %} hidden lg:block {% endif %}">
          <div class="topbar-message text-center rsmb-p">
            {{ text_message }}
          </div>
        </div>
      {% endif %}
      {% if show_currency or show_language or gst.show_account == 'account_top_bar' %}
        <div class="col-right min-[992px]:w-1/3">
          <div class="flex items-center justify-center min-[992px]:justify-end flex-wrap">
            {% if show_language %}
              <div class="language {% if st.hidden_language_tablet_mobile %} hidden lg:block {% endif %}">
                <localization-form>
                  {%- form 'localization'
                    , id: 'FooterLanguageForm'
                    , class: 'localization-form' -%}
                    <div class="no-js-hidden">
                      {%- render 'language-localization'
                        , localPosition: 'FooterLanguage' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              </div>
            {% endif %}
            {% if show_currency %}
              <div class="currency {% if st.hidden_currency_tablet_mobile %} hidden lg:block {% endif %}">
                <localization-form>
                  {%- form 'localization'
                    , id: 'FooterCountryForm'
                    , class: 'localization-form' -%}
                    <div class="no-js-hidden">
                      {%- render 'country-localization'
                        , localPosition: 'FooterCountry' -%}
                    </div>
                  {%- endform -%}
                </localization-form>
              </div>
            {% endif %}
            {%- if shop.customer_accounts_enabled and gst.show_account == 'account_top_bar' -%}
              <div class="tp_account ml-30 {% if st.hidden_account_tablet_mobile %} hidden lg:block {% endif %}">
                {%- if customer -%}
                  <a href="{{ routes.account_url }}">
                    {{ 'customer.account.title' | t }}
                  </a>
                {%- else -%}
                  <a href="{{ routes.account_login_url }}">
                    {{ 'customer.account.login_register' | t }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "Top bar",
    "tag": "section",
    "class": "tp__section mb-0",
    "settings": [
      {
        "type": "select",
        "id": "container",
        "label": "Layout",
        "default": "container",
        "options": [
          {
            "value": "container",
            "label": "Default"
          }, {
            "value": "container-fluid",
            "label": "Fluid container"
          }, {
            "value": "full-width",
            "label": "Full width"
          }
        ]
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.label",
        "default": "background-1"
      },
      {
        "type": "checkbox",
        "id": "show_background_grid",
        "label": "Show background grid",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "border_bottom",
        "label": "Border bottom",
        "default": false
      }, {
        "type": "checkbox",
        "id": "show_social",
        "label": "Show social",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_language",
        "label": "Show language",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_currency",
        "label": "Show currency",
        "default": true
      }, {
        "type": "link_list",
        "id": "menu_top_bar",
        "label": "Menu",
        "info": "Show only the 1st level menu, limit 3 item"
      }, {
        "type": "richtext",
        "id": "message",
        "label": "Message",
        "default": "<p></p>"
      }, {
        "type": "header",
        "content": "Settings Tablet, Mobile"
      }, {
        "type": "checkbox",
        "id": "hidden_top_bar_tablet_mobile",
        "label": "Hide all on tablet, mobile",
        "default": true
      }, {
        "type": "checkbox",
        "id": "hidden_social_tablet_mobile",
        "label": "Hide social on tablet, mobile",
        "default": false
      }, {
        "type": "checkbox",
        "id": "hidden_menu_tablet_mobile",
        "label": "Hide menu on tablet, mobile",
        "default": false
      }, {
        "type": "checkbox",
        "id": "hidden_message_tablet_mobile",
        "label": "Hide message on tablet, mobile",
        "default": false
      }, {
        "type": "checkbox",
        "id": "hidden_language_tablet_mobile",
        "label": "Hide language on tablet, mobile",
        "default": false
      }, {
        "type": "checkbox",
        "id": "hidden_currency_tablet_mobile",
        "label": "Hide currency on tablet, mobile",
        "default": false
      }, {
        "type": "checkbox",
        "id": "hidden_account_tablet_mobile",
        "label": "Hide account on tablet, mobile",
        "default": false
      }
    ],
    "presets": [
      {
        "name": "Top bar"
      }
    ]
  }
{% endschema %}