{% comment %}
  Renders icon with text block

  Accepts:
  - block: {Object} passes in the block information.


  Usage:
  {% render 'icon-with-text',
    block: block
  %}
{% endcomment %}
{%- liquid
  assign heading_1_empty = false
  assign heading_2_empty = false
  assign heading_3_empty = false
  assign text_only_all_items = true

  if block.settings.heading_1 == empty
    assign heading_1_empty = true
  endif

  if block.settings.heading_2 == empty
    assign heading_2_empty = true
  endif

  if block.settings.heading_3 == empty
    assign heading_3_empty = true
  endif

  if heading_1_empty == false and block.settings.icon_1 != 'none' or block.settings.image_1 != null
    assign text_only_all_items = false
  elsif heading_2_empty == false and block.settings.icon_2 != 'none' or block.settings.image_2 != null
    assign text_only_all_items = false
  elsif heading_3_empty == false and block.settings.icon_3 != 'none' or block.settings.image_3 != null
    assign text_only_all_items = false
  endif
-%}
{%- liquid
  assign heading_1_output = block.settings.heading_1
  assign heading_2_output = block.settings.heading_2
  assign heading_3_output = block.settings.heading_3
  assign current_variant = product.selected_or_first_available_variant
  assign current_retiro_tienda = current_variant.metafields.custom.retiro_tienda.value | default: product.metafields.custom.retiro_tienda.value
  assign current_tiempo_rm = current_variant.metafields.custom.tiempo_de_envio_rm.value | default: product.metafields.custom.tiempo_de_envio_rm.value
  assign current_tiempo_regiones = current_variant.metafields.custom.tiempo_de_envio_regiones.value | default: product.metafields.custom.tiempo_de_envio_regiones.value
-%}
{%- if product != blank and heading_1_output contains 'Retiro en tienda' -%}
  {%- capture heading_1_output -%}<strong>Retiro en tienda:</strong> {{ current_retiro_tienda }}{%- endcapture -%}
{%- endif -%}
{%- if product != blank and heading_2_output contains 'RM:' and heading_2_output contains 'Regiones' -%}
  {%- capture heading_2_output -%}<strong>RM:</strong> {{ current_tiempo_rm }} - <strong>Regiones: </strong>{{ current_tiempo_regiones }}{%- endcapture -%}
{%- elsif product != blank and heading_2_output contains 'Tiempo de entrega' and heading_2_output contains 'Regiones' -%}
  {%- capture heading_2_output -%}Tiempo de entrega: <strong>{{ current_tiempo_rm }}</strong> días RM, Regiones  <strong>{{ current_tiempo_regiones }}</strong> días{%- endcapture -%}
{%- endif -%}
<ul
  id="IconWithText-{{ section.id }}-{{ block.id }}"
  data-variant-fragment="icon-with-text"
  class="icon-with-text icon-with-text--{{ block.settings.layout }} {% if text_only_all_items %} icon-with-text--text-only{% endif %} mb-24 ml-0"
  {{ block.shopify_attributes }}
>
  {%- unless heading_1_empty -%}
    <li class="icon-with-text__item">
      {%- if block.settings.image_1 == null -%}
        {%- render 'icon-accordion', icon: block.settings.icon_1 -%}
      {%- else -%}
        <img
          src="{{ block.settings.image_1 | image_url }}"
          {% if block.settings.image_1.alt != blank %}
            alt="{{ block.settings.image_1.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="auto"
          width="auto"
          loading="lazy"
        >
      {%- endif -%}
      <span class="inline-richtext">
        {{- heading_1_output -}}
      </span>
    </li>
  {%- endunless -%}
  {%- unless heading_2_empty -%}
    <li class="icon-with-text__item">
      {%- if block.settings.image_2 == null -%}
        {% render 'icon-accordion', icon: block.settings.icon_2 -%}
      {%- else -%}
        <img
          src="{{ block.settings.image_2 | image_url }}"
          {% if block.settings.image_2.alt != blank %}
            alt="{{ block.settings.image_2.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="auto"
          width="auto"
          loading="lazy"
        >
      {%- endif -%}
      <span class="inline-richtext">
        {{- heading_2_output -}}
      </span>
    </li>
  {%- endunless -%}
  {%- unless heading_3_empty -%}
    <li class="icon-with-text__item">
      {%- if block.settings.image_3 == null -%}
        {% render 'icon-accordion', icon: block.settings.icon_3 -%}
      {%- else -%}
        <img
          src="{{ block.settings.image_3 | image_url }}"
          {% if block.settings.image_3.alt != blank %}
            alt="{{ block.settings.image_3.alt | escape }}"
          {% else %}
            role="presentation"
          {% endif %}
          height="auto"
          width="auto"
          loading="lazy"
        >
      {%- endif -%}
      <span class="inline-richtext">
        {{- heading_3_output -}}
      </span>
    </li>
  {%- endunless -%}
</ul>
