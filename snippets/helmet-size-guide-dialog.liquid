{%- liquid
  assign fallback_guide_image_src = 'https://cdn.shopify.com/s/files/1/0720/2101/6797/files/medidas_cascos.png?v=1773261654'
  assign selected_guide_image_src = guide_image_src | default: fallback_guide_image_src
-%}

<dialog class="helmet-size-guide-dialog" id="HelmetSizeGuideDialog" aria-labelledby="HelmetSizeGuideTitle">
  <div class="helmet-size-guide-dialog__shell">
    <header class="helmet-size-guide-dialog__header">
      <h2 class="helmet-size-guide-dialog__title" id="HelmetSizeGuideTitle">Guia de Tallas</h2>
      <button
        class="helmet-size-guide-dialog__close"
        type="button"
        data-size-guide-close
        aria-label="Cerrar guia de tallas"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
          <path d="M18 6 6 18M6 6l12 12" />
        </svg>
      </button>
    </header>

    <div class="helmet-size-guide-dialog__body">
      {%- if guide_image != blank -%}
        {{
          guide_image
          | image_url: width: 1200
          | image_tag:
            class: 'helmet-size-guide-dialog__image',
            loading: 'lazy',
            alt: 'Guia de tallas de cascos'
        }}
      {%- else -%}
        <img
          class="helmet-size-guide-dialog__image"
          src="{{ selected_guide_image_src }}"
          alt="Guia de tallas de cascos"
          width="1500"
          height="1500"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  </div>
</dialog>
